{
  "name": "claritylang",
  "displayName": "ClarityLang",
  "description": "Language support for ClarityLang — a programming language designed for LLM code generation that transpiles to TypeScript",
  "version": "0.1.0",
  "publisher": "claritylang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "clarity",
    "claritylang",
    "transpiler",
    "llm",
    "programming-language"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/claritylang/claritylang"
  },
  "contributes": {
    "languages": [
      {
        "id": "clarity",
        "aliases": [
          "ClarityLang",
          "Clarity",
          "clarity"
        ],
        "extensions": [
          ".clarity"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/clarity-light.png",
          "dark": "./icons/clarity-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "clarity",
        "scopeName": "source.clarity",
        "path": "./syntaxes/clarity.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "clarity",
        "path": "./snippets/clarity.json"
      }
    ]
  }
}
